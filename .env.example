# Copy to `.env` for local dev, and set the same vars in Vercel
# (Project → Settings → Environment Variables). None of these are committed.

# ── Site ──────────────────────────────────────────────────────────
# Production domain, used for canonical + Open Graph URLs. No trailing slash.
VITE_SITE_URL=https://your-domain.com

# ── Static media — Cloudflare R2 (Unique Operations bucket) ───────
# All site imagery/video lives in the shared R2 bucket under the
# `assets/detailing/` prefix and is served from the bucket's public CDN domain.
# Set this to that domain (no trailing slash) so the app resolves media to R2.
# Leave it unset for local dev to fall back to files in `public/assets/detailing`.
VITE_ASSET_BASE_URL=https://pub-xxxxxxxx.r2.dev

# ── Supabase — "Unique Operations" project ────────────────────────
# Supabase Dashboard → Project → Settings → API. Used by the contact form,
# which submits to the `contact` Edge Function (see supabase/functions/contact).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── R2 credentials (local scripts / uploads only) ─────────────────
# Only needed to upload/manage objects in the bucket from your machine
# (see DEPLOYMENT.md). Never commit real values. The running site does not
# use these — it reads media over the public CDN via VITE_ASSET_BASE_URL.
# R2_ACCOUNT_ID=
# R2_BUCKET=uniquederailing
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
