# Copy to `.env` for local dev, and set the same vars in Vercel
# (Project → Settings → Environment Variables). None of these are committed.

# ── Site ──────────────────────────────────────────────────────────
# Production domain, used for canonical + Open Graph URLs. No trailing slash.
VITE_SITE_URL=https://your-domain.com

# ── Supabase — "Unique Operations" project ────────────────────────
# Supabase Dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Cloudflare R2 (OPTIONAL) ──────────────────────────────────────
# Not required to run: all media is self-hosted in /public and served by
# Vercel's CDN. Set these only if you later choose to serve media from your
# Unique Operations R2 bucket behind a CDN domain, then point VITE_ASSET_BASE_URL
# at that domain (asset paths would need to be prefixed with it).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=unique-operations
# VITE_ASSET_BASE_URL=https://media.your-domain.com
